    {
      "id": "Dkj511wq1wCDt0RI8BulT",
      "type": "text",
      "x": 2456.418226532919,
      "y": 194.82902713181784,
      "width": 254.92255158853834,
      "height": 150,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
