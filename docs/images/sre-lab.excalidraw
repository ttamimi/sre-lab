      "index": "b4Y",
      "roundness": null,
      "seed": 988836885,
      "version": 649,
      "versionNonce": 417858533,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774116454605,
      "link": null,
      "locked": false,
      "text": "Prometheus can't collect its\nown metrics internally. It\nscrapes its metrics just like\nany other target, by going\nout and making an HTTP\nrequest.",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Prometheus can't collect its own metrics internally. It scrapes its metrics just like any other target, by going out and making an HTTP request.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "mkITebvoyeod4TtXVaO8O",
      "type": "text",
      "x": 2418.744896036119,
      "y": 1145.085581535425,
      "width": 313.60929681482645,
      "height": 100,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4Z",
      "roundness": null,
      "seed": 687758299,
      "version": 1987,
      "versionNonce": 841503013,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774116457837,
      "link": null,
      "locked": false,
      "text": "We didn't configure Daemontools\nto capture Vector's logs. Vector\ncan inject its own logs into the\nprocessing pipeline directly.",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "We didn't configure Daemontools to capture Vector's logs. Vector can inject its own logs into the processing pipeline directly.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "gX7sYWSwoml1Fa6e7Szbf",
      "type": "text",
      "x": 3300.608929678638,
      "y": 1141.9954576413286,
      "width": 322.41327394714,
      "height": 100,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b4a",
      "roundness": null,
      "seed": 537354261,
      "version": 2835,
      "versionNonce": 1571611781,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774116457837,
      "link": null,
      "locked": false,
      "text": "Just for variety, we haven't used\nDaemontools here. Instead, we\nconfigured Grafana to manage its\nlog files by itself.",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Just for variety, we haven't used Daemontools here. Instead, we configured Grafana to manage its log files by itself.",
      "autoResize": false,
      "lineHeight": 1.25
    }
  ],
